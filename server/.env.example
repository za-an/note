# 服务端环境配置（复制为 .env 使用）

# LLM：OpenAI 兼容接口，任意兼容服务均可（DeepSeek/通义/vLLM 等）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=deepseek-chat

# Embedding：留空则使用 Chroma 默认本地 embedding（Demo 可用）
# 如需 OpenAI 兼容 embedding 服务，填写以下三项
EMBED_BASE_URL=
EMBED_API_KEY=
EMBED_MODEL=

# ASR 适配层：mock | huawei_sis | xfyun（后两者待实现）
ASR_PROVIDER=mock

# 数据库（默认 SQLite，可换 postgresql+psycopg://...）
DATABASE_URL=sqlite:///./smartstudy.db

# 存储目录
DATA_DIR=./data
